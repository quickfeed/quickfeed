{
  "compilerOptions": {
    "target": "ES2022",
    "noImplicitAny": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": false,
    "jsx": "react",
    "newLine": "LF",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "allowJs": true,
    "noEmit": true,
    "types": ["jest"]
  },
  "include": ["src/**/*"]
}
